<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LaptopStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Laptop" asp-action="Index">LaptopStore</a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Laptop" asp-action="Index">Sản phẩm</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        <!-- Đã thay thế link cũ bằng ViewComponent CartSummary -->
                        <li class="nav-item">
                            @await Component.InvokeAsync("CartSummary")
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top mt-5 py-4 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5>LaptopStore</h5>
                    <p class="text-muted mb-0">Chuyên cung cấp laptop chính hãng: văn phòng, gaming, đồ họa, mỏng nhẹ với giá tốt nhất thị trường.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Liên hệ</h5>
                    <p class="text-muted mb-1">📞 0909 123 456</p>
                    <p class="text-muted mb-0">✉️ support@laptopstore.vn</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Chính sách</h5>
                    <p class="text-muted mb-1">Bảo hành chính hãng 12-24 tháng</p>
                    <p class="text-muted mb-1">Đổi trả trong 7 ngày</p>
                    <p class="text-muted mb-0">Giao hàng toàn quốc</p>
                </div>
            </div>
            <hr />
            <p class="text-center text-muted mb-0">&copy; @DateTime.Now.Year - LaptopStore.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>