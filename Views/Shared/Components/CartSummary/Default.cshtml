@model int
<a class="nav-link text-dark font-weight-bold" asp-controller="Cart" asp-action="Index">
    🛒 Giỏ hàng
    @if (Model > 0)
    {
        <span class="badge bg-danger text-white" style="border-radius: 50%; padding: 2px 6px; font-size: 0.75em; vertical-align: top;">
            @Model
        </span>
    }
</a>