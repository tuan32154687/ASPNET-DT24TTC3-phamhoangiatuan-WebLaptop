@model List<LaptopStore.Models.CartItem>

<div class="container mt-4">
    <h2>Giỏ hàng của bạn</h2>
    @if (Model.Count == 0)
    {
        <p>Giỏ hàng đang trống.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Tên</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price.ToString("N0") VNĐ</td>
                        <td>@item.Quantity</td>
                        <td>
                            <a asp-action="Remove" asp-route-id="@item.LaptopId" class="btn btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <a asp-controller="Laptop" asp-action="Index" class="btn btn-secondary">Tiếp tục mua sắm</a>
</div>