@model IEnumerable<LaptopStore.Models.Laptop>

<div class="container">
    <h2 class="my-4">Danh sách Laptop</h2>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Thương hiệu</th>
                <th>CPU</th>
                <th>Giá</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Brand</td>
                    <td>@item.Cpu</td>
                    <td>@item.Price.ToString("N0") VNĐ</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>