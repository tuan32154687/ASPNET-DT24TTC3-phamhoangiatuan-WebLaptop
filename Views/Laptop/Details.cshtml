@model LaptopStore.Models.Laptop

<div class="container mt-4">
    <h2>Chi tiết sản phẩm: @Model.Name</h2>
    <hr />
    <div class="row">
        <div class="col-md-5">
            <img src="@Model.ImageUrl"
                 onerror="this.onerror=null;this.src='/images/no-image.png';"
                 class="img-fluid rounded border"
                 style="width:100%; max-height:360px; object-fit:contain; background:#f8f9fa; padding:15px;"
                 alt="@Model.Name">
        </div>
        <div class="col-md-7">
            <p><strong>Thương hiệu:</strong> @Model.Brand</p>
            <p><strong>CPU:</strong> @Model.Cpu</p>
            <p><strong>RAM:</strong> @Model.Ram</p>
            <p><strong>Dung lượng:</strong> @Model.Storage</p>
            <p><strong>GPU:</strong> @Model.Gpu</p>
            <p><strong>Màn hình:</strong> @Model.ScreenSize</p>
            <p><strong>Giá:</strong> <span class="fw-bold text-danger fs-4">@Model.Price.ToString("N0") VNĐ</span></p>

            <p class="mt-3"><strong>Mô tả:</strong></p>
            <p>@Model.Description</p>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>

                <!-- Nút bấm đã được sửa để gọi hàm JavaScript thay vì submit form trực tiếp -->
                <button type="button" class="btn btn-primary" onclick="addToCart()">Thêm vào giỏ hàng</button>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <h4 class="mb-3">Thông số kỹ thuật chi tiết</h4>
            <table class="table table-bordered table-striped align-middle">
                <tbody>
                    <tr>
                        <th style="width: 25%;">Tên sản phẩm</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Thương hiệu</th>
                        <td>@Model.Brand</td>
                    </tr>
                    @if (Model.Category != null)
                    {
                        <tr>
                            <th>Danh mục</th>
                            <td>@Model.Category.Name</td>
                        </tr>
                    }
                    <tr>
                        <th>Vi xử lý (CPU)</th>
                        <td>@Model.Cpu</td>
                    </tr>
                    <tr>
                        <th>RAM</th>
                        <td>@Model.Ram</td>
                    </tr>
                    <tr>
                        <th>Ổ cứng</th>
                        <td>@Model.Storage</td>
                    </tr>
                    <tr>
                        <th>Card đồ họa (GPU)</th>
                        <td>@Model.Gpu</td>
                    </tr>
                    <tr>
                        <th>Màn hình</th>
                        <td>@Model.ScreenSize</td>
                    </tr>
                    <tr>
                        <th>Tình trạng kho</th>
                        <td>
                            @if (Model.Stock > 0)
                            {
                                <span class="text-success">Còn hàng (@Model.Stock sản phẩm)</span>
                            }
                            else
                            {
                                <span class="text-danger">Hết hàng</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Giá bán</th>
                        <td class="fw-bold text-danger">@Model.Price.ToString("N0") VNĐ</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Khai báo section Scripts để _Layout.cshtml có thể render -->
@section Scripts {
    <script>
        function addToCart() {
            // 1. Hiện thông báo đẹp mắt
            Swal.fire({
                icon: 'success',
                title: 'Thêm vào giỏ hàng thành công!',
                showConfirmButton: false,
                timer: 1500
            }).then(() => {
                // 2. Sau khi thông báo xong thì tự động submit form ẩn
                // Tạo một form ẩn
                var form = document.createElement('form');
                form.method = 'POST';
                // Đảm bảo action trỏ đúng về controller Laptop và action AddToCart
                form.action = '@Url.Action("AddToCart", "Laptop")';

                // Thêm input ẩn chứa ID sản phẩm
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'id';
                input.value = '@Model.Id';

                form.appendChild(input);
                document.body.appendChild(form);

                // Gửi form đi
                form.submit();
            });
        }
    </script>
}