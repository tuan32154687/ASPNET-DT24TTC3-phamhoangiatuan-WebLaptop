@model LaptopStore.Models.Order

<h2>Đặt hàng thành công!</h2>
<p>Cảm ơn bạn đã mua hàng. Mã đơn hàng của bạn là: <strong>@Model.Id</strong></p>
<hr />
<h4>Thông tin đơn hàng:</h4>
<p>Người nhận: @Model.ReceiverName</p>
<p>SĐT: @Model.PhoneNumber</p>
<p>Địa chỉ: @Model.ShippingAddress</p>
<p>Tổng tiền: @Model.TotalAmount.ToString("C0")</p>

<a asp-controller="Laptop" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>